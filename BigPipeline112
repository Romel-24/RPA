            select_branch_by_index(driver, idx)

            for c_idx, v_idx, nombre_comb, filename in pendientes_sucursal:
                print(f"  -> Procesando: {nombre_comb}")
                try:
                    # perform_combination ahora retorna True si el archivo se guardó físicamente
                    exito = perform_combination(driver, c_idx, v_idx, branch_name, date_str)
                    
                    if exito:
                        # SOLO ESCRIBIMOS EN EL LOG SI EL ARCHIVO EXISTE
