        os.makedirs(directory)

def is_valid_excel(file_path):
    """Verifica si un archivo Excel es válido."""
    try:
        if not os.path.exists(file_path):
            return False
        size = os.path.getsize(file_path)
        if size < MIN_FILE_SIZE:
            print(f"    Archivo demasiado pequeño: {size} bytes")
            return False
        with zipfile.ZipFile(file_path, 'r') as zip_file:
            required_files = ['[Content_Types].xml', 'xl/workbook.xml']
            for req in required_files:
                if req not in zip_file.namelist():
                    print(f"    Archivo Excel corrupto: falta {req}")
                    return False
        return True
    except zipfile.BadZipFile:
        print(f"    Archivo no es un ZIP válido")
        return False
    except Exception as e:
        print(f"    Error al validar archivo: {e}")
        return False

def clean_download_folder():
    """Mueve todos los archivos .xlsx existentes a una subcarpeta de backup."""
    backup_dir = os.path.join(DOWNLOAD_DIR, "backup_" + datetime.now().strftime("%Y%m%d"))
    os.makedirs(backup_dir, exist_ok=True)
    moved = 0
    for f in os.listdir(DOWNLOAD_DIR):
        if f.endswith('.xlsx') and not f.startswith('backup'):
            shutil.move(os.path.join(DOWNLOAD_DIR, f), os.path.join(backup_dir, f))
            moved += 1
    if moved > 0:
        print(f"  Archivos previos movidos a backup: {moved}")

def wait_for_download_complete(timeout=WAIT_FOR_DOWNLOAD):
    start_time = time.time()
    # Obtener archivos .xlsx que ya existían antes de la descarga
    initial_xlsx = set(f for f in os.listdir(DOWNLOAD_DIR) if f.endswith('.xlsx'))

    while time.time() - start_time < timeout:
        files = os.listdir(DOWNLOAD_DIR)
        crdownload = [f for f in files if f.endswith('.crdownload')]
        if crdownload:
            # Aún descargando
            time.sleep(1)
            continue

        # Ya no hay .crdownload -> buscar .xlsx que no estuviera al inicio
        current_xlsx = set(f for f in files if f.endswith('.xlsx'))
        new_xlsx = current_xlsx - initial_xlsx
        if new_xlsx:
            latest = max(new_xlsx, key=lambda f: os.path.getctime(os.path.join(DOWNLOAD_DIR, f)))
            print(f"    Archivo detectado: {latest}")
            return latest

        time.sleep(1)
    return None

def safe_click(driver, element, timeout=10):
    wait_for_overlay_to_disappear(driver)
    try:
        human_mouse_movement(driver, element)
        WebDriverWait(driver, timeout).until(EC.element_to_be_clickable(element))
        element.click()
        human_delay(0.1, 0.4)
        return True
    except:
        try:
            driver.execute_script("arguments[0].click();", element)
            human_delay(0.1, 0.4)
            return True
        except:
            return False

def wait_for_overlay_to_disappear(driver, timeout=30):
    overlay_xpaths = [
        "//div[contains(@class, 'p-component-overlay')]",
        "//div[contains(@class, 'p-dialog-mask')]",
    ]
    for xpath in overlay_xpaths:
        try:
            WebDriverWait(driver, timeout).until(
                EC.invisibility_of_element_located((By.XPATH, xpath))
            )
        except:
            pass

