def cargar_log_descargas(ruta_log):
    """Lee el archivo .txt y retorna un set con los nombres de los archivos ya descargados."""
    if not os.path.exists(ruta_log):
        return set()
    with open(ruta_log, 'r', encoding='utf-8') as f:
        return set(line.strip() for line in f if line.strip())

def registrar_en_log(ruta_log, nombre_archivo):
    """Añade una nueva línea al archivo .txt con el nombre del archivo descargado."""
    with open(ruta_log, 'a', encoding='utf-8') as f:
        f.write(nombre_archivo + '\n')

def registrar_timestamp_descarga(nombre_archivo):
    """
    Guarda en un archivo JSON la marca de tiempo de descarga para un archivo.
    """
    timestamp = datetime.now()
    timestamp_str = timestamp.isoformat()
    timestamp_file = os.path.join(LOG_DIR, "download_timestamps.json")
    # Cargar diccionario existente
    try:
        with open(timestamp_file, 'r', encoding='utf-8') as f:
            timestamps = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        timestamps = {}
    # Actualizar con el nuevo archivo
    timestamps[nombre_archivo] = timestamp_str
    # Guardar de vuelta
    with open(timestamp_file, 'w', encoding='utf-8') as f:
        json.dump(timestamps, f, indent=2)

def cargar_timestamps():
    """
    Lee el archivo de timestamps y devuelve un diccionario {nombre_archivo: timestamp_iso}
    """
    timestamp_file = os.path.join(LOG_DIR, "download_timestamps.json")
    try:
        with open(timestamp_file, 'r', encoding='utf-8') as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}

def clean_target_dir(directory):
    """Elimina todos los archivos y carpetas dentro de TARGET_DIR."""
    if not os.path.exists(directory):
        return
    print("  [LIMPIEZA] Eliminando archivos viejos en:", directory)
    for filename in os.listdir(directory):
        file_path = os.path.join(directory, filename)
        try:
            if os.path.isfile(file_path) or os.path.islink(file_path):
                os.unlink(file_path)
            elif os.path.isdir(file_path):
                shutil.rmtree(file_path)
        except Exception as e:
            print(f"    Error al eliminar {file_path}: {e}")
    print("  [LIMPIEZA] Limpieza completada.")

def generar_reporte_estadistico(df, tabla, engine):
    """
    Genera un archivo Excel con análisis estadístico del proceso de carga.
    Retorna la ruta del archivo generado.
    """
    print("\n[REPORTE] Generando análisis estadístico...")
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    reporte_path = os.path.join(REPORTE, f"reporte_carga_Visor_{timestamp}.xlsx")
    
    with pd.ExcelWriter(reporte_path, engine='openpyxl') as writer:
        # Hoja 1: Resumen general
        resumen = pd.DataFrame({
            "Fecha": [datetime.now().strftime("%Y-%m-%d %H:%M:%S")],
            "Total filas cargadas": [len(df)],
            "Total columnas": [len(df.columns)],
            "Nombre tabla destino": [tabla]
        })
        resumen.to_excel(writer, sheet_name="Resumen", index=False)
        
        # Hoja 2: Distribución por sucursal
        if 'Sucursal' in df.columns:
            distrib_suc = df['Sucursal'].value_counts().reset_index()
            distrib_suc.columns = ['Sucursal', 'Cantidad']
            distrib_suc.to_excel(writer, sheet_name="Por Sucursal", index=False)
        
        # Hoja 3: Distribución por estatus
        if 'Estatus_compra' in df.columns and 'Estatus_venta' in df.columns:
            distrib_est = df.groupby(['Estatus_compra', 'Estatus_venta']).size().reset_index(name='Cantidad')
            distrib_est.to_excel(writer, sheet_name="Por Estatus", index=False)
        
        # Hoja 4: Estadísticas numéricas
        cols_numericas = df.select_dtypes(include=['number']).columns
        if len(cols_numericas) > 0:
            stats = df[cols_numericas].describe().transpose()
            stats.to_excel(writer, sheet_name="Estadísticas Numéricas")
        
        # Hoja 5: Nulos por columna
        nulos = df.isnull().sum().reset_index()
        nulos.columns = ['Columna', 'Valores Nulos']
        nulos['Porcentaje'] = (nulos['Valores Nulos'] / len(df)) * 100
        nulos.to_excel(writer, sheet_name="Nulos por Columna", index=False)
        
        # Hoja 6: Muestra de datos (primeras 100 filas)
        df.head(100).to_excel(writer, sheet_name="Muestra Datos", index=False)
    
    print(f"  [REPORTE] Archivo guardado en: {reporte_path}")
    return reporte_path

