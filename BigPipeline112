def extraer_sucursal(nombre_archivo: str) -> str:
    """
    Extrae la sucursal del nombre del archivo.
    Se asume que el nombre tiene la forma: <sucursal>_Visor_...
    Retorna la parte anterior a "_Visor".
    """
    patron = r'^(.*?)_Visor'
    match = re.search(patron, nombre_archivo)
    if match:
        return match.group(1)
    else:
        print(f"  [WARN] No se pudo extraer sucursal del archivo {nombre_archivo}")
        return "Desconocida"

def extraer_estatus(nombre_archivo: str):
    """
    Extrae los estados de compra y venta del nombre del archivo.
    Formato esperado: ..._C_Activo_V_ActivoDDMMYYYY o ..._C_Activo_V_Activo_DDMMYYYY
    Retorna (estatus_compra, estatus_venta) como strings "Activo"/"Inactivo".
    """
    patron = r'C_(\w+)_V_(\w+)(?:_\d+|\d+)?'
    match = re.search(patron, nombre_archivo)
    if match:
        compra = match.group(1)
        venta = match.group(2)
        # Eliminar dígitos que puedan haber quedado pegados al estado (por si la fecha no tiene separador)
        venta = re.sub(r'\d+$', '', venta)
        return compra, venta
    else:
        print(f"  [WARN] No se pudo extraer estado del archivo {nombre_archivo}")
        return "Desconocido", "Desconocido"

def limpiar_y_convertir(df: pd.DataFrame) -> pd.DataFrame:
    """
    Limpia y convierte los tipos de datos según lo requerido:
    - Remueve "Bs. ", "$ ", comas, puntos de miles y convierte correctamente los decimales.
    - Convierte a numérico (float) las columnas monetarias.
    - Convierte a entero las columnas de unidades y disponibles.
    """
    print("  [DEBUG] Limpiando y convirtiendo tipos de datos...")

    # Columnas que deben ser enteras
    cols_int = ["Unidades", "Disponible", "Total unidades"]

    # Columnas que deben ser decimales (se eliminan símbolos monetarios)
    cols_decimal = [
        "Costo base", "Costo conversión", "Factor neto",
        "Costo neto base", "Costo neto conversión", "Factor neto venta",
        "Costo neto venta base", "Costo neto venta conversión", "Factor venta",
        "PVP base", "PVP conversión"
    ]

    # Diccionario de limpieza: columna -> símbolo a quitar y formato esperado
    # Formato: (simbolo, usar_formato_espanol)
    # Para Bs. se usa formato español (punto miles, coma decimal)
    # Para $ se usa formato inglés (coma miles, punto decimal)
    formatos = {
        "Costo base": ("Bs.", False),
        "Costo neto base": ("Bs.", False),
        "Costo neto venta base": ("Bs.", False),
        "PVP base": ("Bs.", False),
        "Costo conversión": ("$", False),
        "Costo neto conversión": ("$", False),
        "Costo neto venta conversión": ("$", False),
        "PVP conversión": ("$", False),
        # Los factores no llevan símbolo, pero pueden tener separadores
        "Factor neto": (None, True),
        "Factor neto venta": (None, True),
        "Factor venta": (None, True),
    }

    for col in cols_decimal:
        if col not in df.columns:
            print(f"    [WARN] Columna '{col}' no encontrada, se omite.")
            continue

        # Convertir a string
        df[col] = df[col].astype(str)

        # Obtener formato
        simbolo, es_espanol = formatos.get(col, (None, False))

        # Eliminar símbolo monetario si existe
        if simbolo:
            df[col] = df[col].str.replace(simbolo, "", regex=False)

        # Limpiar espacios sobrantes
        df[col] = df[col].str.strip()

        # Manejar separadores según el formato
        if es_espanol:
            # Formato español: punto como separador de miles, coma como decimal
            # Ejemplo: "1.234,56" -> "1234,56" -> luego reemplazar coma por punto
            df[col] = df[col].str.replace(".", "", regex=False)   # quitar puntos de miles
            df[col] = df[col].str.replace(",", ".", regex=False)  # coma decimal -> punto
        else:
            # Formato inglés: coma como separador de miles, punto como decimal
            # Ejemplo: "1,234.56" -> "1234.56"
            df[col] = df[col].str.replace(",", "", regex=False)   # quitar comas de miles
            # El punto decimal se mantiene

        # Convertir a numérico (float64)
        df[col] = pd.to_numeric(df[col], errors='coerce')

    # Limpiar y convertir columnas enteras
    for col in cols_int:
        if col not in df.columns:
            print(f"    [WARN] Columna '{col}' no encontrada, se omite.")
            continue

        # Convertir a numérico (puede tener decimales .0)
        df[col] = pd.to_numeric(df[col], errors='coerce')
        # Redondear para eliminar decimales (ej. 10.0 -> 10)
        df[col] = df[col].round(0)
        # Convertir a Int64 nullable (permite NaN)
        df[col] = df[col].astype('Int64')

    print("  [DEBUG] Conversión finalizada.")
    return df

def dividir_categoria(df: pd.DataFrame) -> pd.DataFrame:
    """
    Divide la columna 'Categoría' por '>>' en tres columnas:
    Categoría, Subcategoria1, Subcategoria2.
    """
    print("     [DETAIL] Ejecutando dividir_categoria...")
    split_df = df['Categoría'].str.split('>>', n=2, expand=True)

    # Asegurar que siempre haya 3 columnas
    for i in range(3):
        if i not in split_df.columns:
            split_df[i] = None

    split_df.columns = ['Categoría', 'Subcategoria1', 'Subcategoria2']
    split_df = split_df.fillna('')

    df = df.drop(columns=['Categoría'])
    return pd.concat([df, split_df], axis=1)

def procesar_archivo(ruta_archivo: str, timestamps: dict) -> pd.DataFrame:
    """
    Lee un archivo (Excel o CSV), limpia datos y añade columnas de estado y sucursal.
    Además agrega la columna 'Fecha_hora_descarga' a partir del diccionario de timestamps.
    """
    nombre_base = os.path.basename(ruta_archivo)
    print(f"  [DEBUG] Procesando archivo: {nombre_base}")

    if ruta_archivo.endswith('.xlsx'):
        df = pd.read_excel(ruta_archivo)
    elif ruta_archivo.endswith('.csv'):
        df = pd.read_csv(ruta_archivo)
    else:
        print(f"  [WARN] Extensión no soportada: {ruta_archivo}")
        return pd.DataFrame()

    print(f"    [DEBUG] {len(df)} filas leídas. Dividiendo categoría...")
    df = dividir_categoria(df)

    df = limpiar_y_convertir(df)

    # Añadir columna de sucursal reemplazando guiones bajos por espacios
    sucursal = extraer_sucursal(nombre_base).replace('_', ' ')
    df['Sucursal'] = sucursal
    print(f"    [DEBUG] Sucursal = '{sucursal}'")

    # Añadir columnas de estado
    compra, venta = extraer_estatus(nombre_base)
    df['Estatus_compra'] = compra
    df['Estatus_venta'] = venta
    print(f"    [DEBUG] Estado compra = '{compra}', estado venta = '{venta}'.")

    # ========== NUEVO: Agregar columna de fecha/hora de descarga ==========
    timestamp_str = timestamps.get(nombre_base)
    if timestamp_str:
        df['Fecha_hora_descarga'] = pd.to_datetime(timestamp_str)
        print(f"    [DEBUG] Fecha/hora descarga = {timestamp_str}")
    else:
        df['Fecha_hora_descarga'] = pd.NaT
        print(f"    [WARN] No se encontró timestamp para {nombre_base}. Se asigna NaT.")

    print(f"    [DEBUG] DataFrame final shape: {df.shape}")
    return df

def procesar_carpeta(ruta_carpeta: str, timestamps: dict) -> pd.DataFrame:
    """
    Procesa todos los archivos .xlsx y .csv dentro de la carpeta.
    Retorna un único DataFrame con la unión de todos.
    """
    print(f"[PROCESO] Buscando archivos en: {ruta_carpeta}")
    archivos = glob.glob(os.path.join(ruta_carpeta, "*.xlsx")) + \
               glob.glob(os.path.join(ruta_carpeta, "*.csv"))
    print(f"[PROCESO] Encontrados {len(archivos)} archivos.")

    df_list = []
    for archivo in archivos:
        df = procesar_archivo(archivo, timestamps)
        if not df.empty:
            df_list.append(df)

    if not df_list:
        print("[ERROR] No se pudo cargar ningún archivo.")
        return pd.DataFrame()

    df_final = pd.concat(df_list, ignore_index=True)
    print(f"[PROCESO] Total de filas después de unir: {len(df_final)}")
    return df_final

def cargar_a_postgres(df: pd.DataFrame, tabla: str, engine):
    """
    Carga el DataFrame a PostgreSQL, truncando la tabla si existe.
    Se especifican los tipos de datos SQL deseados para ciertas columnas.
    """
    print(f"\n[CARGA] Conectando a base de datos (tabla: {tabla})...")

    dtype_mapping = {}

    # Columnas decimales
    cols_decimal = [
        "Costo base", "Costo conversión", "Factor neto",
        "Costo neto base", "Costo neto conversión", "Factor neto venta",
        "Costo neto venta base", "Costo neto venta conversión", "Factor venta",
        "PVP base", "PVP conversión"
    ]
    for col in cols_decimal:
        if col in df.columns:
            dtype_mapping[col] = types.Numeric(precision=15, scale=2)

    # Columnas enteras
    cols_int = ["Unidades", "Disponible", "Total unidades"]
    for col in cols_int:
        if col in df.columns:
            dtype_mapping[col] = types.Integer

    # ========== NUEVO: Tipo para la columna de fecha/hora ==========
    if 'Fecha_hora_descarga' in df.columns:
        dtype_mapping['Fecha_hora_descarga'] = types.DateTime

    with engine.connect() as conn:
        inspector = inspect(engine)
        if tabla in inspector.get_table_names():
            print(f"  [CARGA] La tabla '{tabla}' ya existe. Truncando...")
            conn.execute(text(f"TRUNCATE TABLE {tabla} RESTART IDENTITY;"))
            conn.commit()
            print("  [CARGA] Truncado exitoso.")
        else:
            print(f"  [CARGA] La tabla '{tabla}' no existe. Se creará durante la inserción.")

        print(f"  [CARGA] Insertando {len(df)} filas...")
        df.to_sql(tabla, engine, if_exists='append', index=False, dtype=dtype_mapping, method='multi', chunksize=1000)
        print("  [CARGA] Inserción completada.")
        conn.commit()

