def iniciando_navegacion():
    options = Options()
    options.add_experimental_option("detach", True)
    
    options.add_argument("--disable-blink-features=AutomationControlled")
    options.add_experimental_option("excludeSwitches", ["enable-automation"])
    options.add_experimental_option("useAutomationExtension", False)
    
    options.add_argument('--ignore-certificate-errors')
    options.add_argument('--ignore-ssl-errors')
    options.add_argument('--allow-insecure-localhost')
    
    options.add_argument("user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36")
    
    options.add_argument('--disable-dev-shm-usage')
    options.add_argument('--no-sandbox')
    
    # Configurar descargas
    download_dir = os.path.join(os.path.expanduser('~'), 'Downloads')
    prefs = {
        "download.default_directory": download_dir,
        "download.prompt_for_download": False,
        "download.directory_upgrade": True,
        "safebrowsing.enabled": True
    }
    options.add_experimental_option("prefs", prefs)
    
    try:
        ssl._create_default_https_context = ssl._create_unverified_context
        
        service = Service(ChromeDriverManager().install())
        driver = webdriver.Chrome(service=service, options=options)
        driver.maximize_window()
        
        driver.execute_script("Object.defineProperty(navigator, 'webdriver', {get: () => undefined})")
        
        print("✅ Navegador iniciado correctamente")
        return driver, download_dir
        
    except Exception as e:
        print(f"❌ Error al iniciar navegador: {e}")
        raise

def obtener_nombre_archivo_fecha():
    """
    Obtiene el nombre del archivo basado en la fecha del día anterior.
    Formato: Reporte-Ajuste-Inventario+DDMMYYYY
    Ejemplo: Reporte-Ajuste-Inventario+09012026
    CORREGIDO: Asegura formato de 2 dígitos para día y mes
    """
    ayer = datetime.now() - timedelta(days=1)
    
    # CORRECCIÓN: Usar formato con ceros a la izquierda
    fecha_formateada = ayer.strftime("%d%m%Y")  # Esto ya da "09" "01" "2026"
    
    # Verificar que la fecha sea válida
    if len(fecha_formateada) != 8:
        print(f"   ⚠️ ADVERTENCIA: Fecha formateada incorrecta: {fecha_formateada}")
        # Usar fecha de hoy como respaldo
        hoy = datetime.now()
        fecha_formateada = hoy.strftime("%d%m%Y")
        print(f"   🔧 Usando fecha actual: {fecha_formateada}")
    
    nombre_archivo = f"Reporte-Ajuste-Inventario+{fecha_formateada}.xlsx"
    return nombre_archivo, ayer

def esperar_descarga_archivo(download_dir, timeout=120):
    """
    Espera a que se complete la descarga del archivo Excel.
    Retorna el path del archivo descargado.
    CORREGIDA: Mejor detección de archivos Excel.
    """
    print("\n" + "="*60)
    print("⏳ ESPERANDO DESCARGA DEL ARCHIVO EXCEL (MEJORADO)")
    print("="*60)
    
    tiempo_inicio = time.time()
    archivo_descargado = None
    archivos_vistos = set()
    
    print(f"   Directorio de descarga: {download_dir}")
    print(f"   Tiempo máximo de espera: {timeout} segundos")
    
    # Listar archivos existentes antes de empezar
    archivos_iniciales = set()
    try:
        for f in os.listdir(download_dir):
            if f.endswith(('.xlsx', '.xls', '.csv')):
                archivos_iniciales.add(os.path.join(download_dir, f))
    except:
        pass
    
    while time.time() - tiempo_inicio < timeout:
        tiempo_transcurrido = int(time.time() - tiempo_inicio)
        print(f"   Esperando descarga... ({tiempo_transcurrido}/{timeout} segundos)")
        
        # Buscar archivos nuevos
        try:
            archivos_actuales = []
            for f in os.listdir(download_dir):
                if f.endswith(('.xlsx', '.xls', '.csv')):
                    ruta_completa = os.path.join(download_dir, f)
                    archivos_actuales.append(ruta_completa)
                    
                    # Es un archivo nuevo si no estaba en la lista inicial
                    if ruta_completa not in archivos_iniciales and ruta_completa not in archivos_vistos:
                        # Verificar que no sea un archivo temporal
                        if not f.endswith('.crdownload') and not f.endswith('.tmp'):
                            tamaño = os.path.getsize(ruta_completa) if os.path.exists(ruta_completa) else 0
                            if tamaño > 1024:  # Al menos 1KB
                                print(f"   📥 Nuevo archivo detectado: {f}")
                                print(f"      Tamaño: {tamaño} bytes")
                                archivos_vistos.add(ruta_completa)
                                archivo_descargado = ruta_completa
                                
                                # Esperar un poco más para asegurar que la descarga completó
                                print(f"      ⏱️  Esperando 3 segundos para confirmar...")
                                time.sleep(3)
                                return archivo_descargado
        except Exception as e:
            print(f"   ⚠️ Error leyendo directorio: {e}")
        
        # Verificar archivos .crdownload (descarga en progreso)
        archivos_temp = glob.glob(os.path.join(download_dir, "*.crdownload"))
        if archivos_temp:
            print(f"   ⏳ Descarga en progreso... archivos temporales: {len(archivos_temp)}")
            for temp in archivos_temp[:2]:  # Mostrar primeros 2
                print(f"      • {os.path.basename(temp)}")
        
        time.sleep(3)
    
    print(f"   ⚠️ Tiempo de espera excedido ({timeout} segundos)")
    
    # Último intento: buscar cualquier archivo Excel que pueda ser el descargado
    print(f"   🔍 Buscando archivos Excel disponibles...")
    archivos_excel = []
    for ext in ['*.xlsx', '*.xls']:
        archivos_excel.extend(glob.glob(os.path.join(download_dir, ext)))
    
    if archivos_excel:
        # Excluir archivos que estaban inicialmente
        archivos_nuevos = [f for f in archivos_excel if f not in archivos_iniciales]
        
        if archivos_nuevos:
            # Tomar el más reciente
            archivos_nuevos.sort(key=os.path.getmtime, reverse=True)
            archivo_mas_reciente = archivos_nuevos[0]
            print(f"   📄 Usando archivo más reciente: {os.path.basename(archivo_mas_reciente)}")
            return archivo_mas_reciente
        else:
            # Si no hay nuevos, usar el más reciente de todos modos
            archivos_excel.sort(key=os.path.getmtime, reverse=True)
            archivo_mas_reciente = archivos_excel[0]
            print(f"   📄 Usando archivo disponible más reciente: {os.path.basename(archivo_mas_reciente)}")
            return archivo_mas_reciente
    
    print(f"   ❌ No se encontraron archivos Excel en {download_dir}")
    return None

def renombrar_y_mover_archivo(archivo_descargado, download_dir):
    """
    Renombra y mueve el archivo descargado a la carpeta especificada.
    CORREGIDA: Maneja mejor rutas, permisos y verificación.
    """
    print("\n" + "="*60)
    print("📁 RENOMBRANDO Y MOVIENDO ARCHIVO (VERSIÓN CORREGIDA)")
    print("="*60)
    
    if not archivo_descargado or not os.path.exists(archivo_descargado):
        print("   ❌ ERROR: No hay archivo descargado o no existe")
        return False, None
    
    # Obtener el nombre del archivo basado en la fecha
    nombre_nuevo, fecha_ayer = obtener_nombre_archivo_fecha()
    print(f"   Fecha del archivo: {fecha_ayer.strftime('%d/%m/%Y')}")
    print(f"   Nombre nuevo: {nombre_nuevo}")
    print(f"   Archivo descargado: {os.path.basename(archivo_descargado)}")
    print(f"   Tamaño: {os.path.getsize(archivo_descargado):,} bytes")
    
    # CORRECCIÓN: Rutas correctamente escapadas para Windows
    rutas_posibles = [
        r"Z:\Reportes\Ajustes",  # ← CORREGIDO: Usar raw string (r"")
        r"C:\Reportes\Ajustes",
        os.path.join(os.path.expanduser('~'), 'Documents', 'Reportes_Ajustes'),
        os.path.join(os.path.expanduser('~'), 'Desktop', 'Reportes_Ajustes'),
        os.path.join(download_dir, 'Reportes_Ajustes')
    ]
    
    ruta_destino = None
    
    # Buscar la primera ruta válida o crear una
    for ruta in rutas_posibles:
        try:
            print(f"   Probando ruta: {ruta}")
            
            # Verificar si es una unidad de red
            if ruta.startswith(r"Z:\\") or ruta.startswith("Z:\\"):
                # Verificar si la unidad Z: existe
                if not os.path.exists(r"Z:\\"):
                    print(f"      ⚠️ Unidad Z: no disponible, probando siguiente...")
                    continue
                
                # Verificar si la carpeta existe en Z:, si no, intentar crearla
                if not os.path.exists(ruta):
                    try:
                        print(f"      🔧 Creando directorio en unidad de red...")
                        os.makedirs(ruta, exist_ok=True)
                        print(f"      ✅ Directorio creado en unidad de red")
                    except Exception as e:
                        print(f"      ⚠️ No se pudo crear directorio en unidad de red: {e}")
                        continue
            else:
                # Para rutas locales, crear si no existen
                if not os.path.exists(ruta):
                    print(f"      🔧 Creando directorio local...")
                    os.makedirs(ruta, exist_ok=True)
                    print(f"      ✅ Directorio local creado")
            
            # Verificar permisos de escritura (solo para rutas accesibles)
            try:
                archivo_test = os.path.join(ruta, 'test_permissions.tmp')
                with open(archivo_test, 'w') as f:
                    f.write('test')
                os.remove(archivo_test)
                ruta_destino = ruta
                print(f"      ✅ Ruta válida y con permisos de escritura")
                break
            except Exception as e:
                print(f"      ⚠️ Sin permisos de escritura en {ruta}: {e}")
                continue
                
        except Exception as e:
            print(f"      ⚠️ Error con ruta {ruta}: {e}")
            continue
    
    if not ruta_destino:
        print("   ❌ ERROR: No se pudo encontrar o crear una ruta válida")
        # Usar una ruta en el directorio de descargas como último recurso
        ruta_destino = os.path.join(download_dir, 'Reportes_Ajustes')
        os.makedirs(ruta_destino, exist_ok=True)
        print(f"   🔧 Usando ruta alternativa: {ruta_destino}")
    
    # Ruta completa del archivo nuevo
    ruta_nueva = os.path.join(ruta_destino, nombre_nuevo)
    print(f"\n   📍 Ruta destino final: {ruta_destino}")
    print(f"   📄 Archivo destino: {ruta_nueva}")
    
    try:
        # NUEVA ESTRATEGIA: Manejo inteligente de archivos existentes
        if os.path.exists(ruta_nueva):
            print(f"   ⚠️ Ya existe un archivo con el nombre {nombre_nuevo}")
            print(f"   📊 Tamaño existente: {os.path.getsize(ruta_nueva):,} bytes")
            print(f"   📅 Modificado: {datetime.fromtimestamp(os.path.getmtime(ruta_nueva)).strftime('%Y-%m-%d %H:%M:%S')}")
            
            # INTENTAR DIFERENTES ESTRATEGIAS EN ORDEN:
            
            # Estrategia 1: Intentar eliminar con diferentes métodos
            print(f"   🔧 Intentando manejar archivo existente...")
            
            archivo_eliminado = False
            archivo_renombrado = False
            
            # Método 1: Intentar eliminar normalmente
            try:
                os.remove(ruta_nueva)
                archivo_eliminado = True
                print(f"   ✅ Archivo existente eliminado exitosamente")
            except Exception as e:
                print(f"   ⚠️ No se pudo eliminar (Método 1): {e}")
                
                # Método 2: Intentar con permisos elevados (simulado)
                try:
                    # Usar shutil.rmtree para carpetas o archivos bloqueados
                    import stat
                    os.chmod(ruta_nueva, stat.S_IWRITE)  # Dar permisos de escritura
                    os.remove(ruta_nueva)
                    archivo_eliminado = True
                    print(f"   ✅ Archivo existente eliminado (con permisos)")
                except:
                    print(f"   ⚠️ No se pudo eliminar (Método 2)")
            
            # Si no se pudo eliminar, intentar renombrar
            if not archivo_eliminado:
                try:
                    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
                    ruta_backup = os.path.join(ruta_destino, f"backup_{timestamp}_{nombre_nuevo}")
                    
                    # Método 3: Intentar renombrar (mover)
                    shutil.move(ruta_nueva, ruta_backup)
                    archivo_renombrado = True
                    print(f"   ✅ Archivo existente renombrado a: {os.path.basename(ruta_backup)}")
                except Exception as e:
                    print(f"   ⚠️ No se pudo renombrar: {e}")
                    
                    # Estrategia final: Sobrescribir directamente durante la copia
                    print(f"   ⚠️ El archivo está bloqueado, intentando sobrescribir durante copia...")
        
        # Copiar el archivo (con manejo de sobrescritura)
        print(f"   📋 Copiando archivo...")
        
        # ESTRATEGIA MEJORADA DE COPIA:
        copia_exitosa = False
        
        # Intentar diferentes métodos de copia
        metodos_copia = [
            ("shutil.copy2", lambda: shutil.copy2(archivo_descargado, ruta_nueva)),
            ("shutil.copy", lambda: shutil.copy(archivo_descargado, ruta_nueva)),
            ("copia manual", lambda: 
                (open(ruta_nueva, 'wb').write(open(archivo_descargado, 'rb').read()) 
                 if not os.path.exists(ruta_nueva) else None))
        ]
        
        for metodo_nombre, metodo_func in metodos_copia:
            if copia_exitosa:
                break
                
            try:
                print(f"      Intentando con {metodo_nombre}...")
                metodo_func()
                print(f"      ✅ {metodo_nombre} exitoso")
                copia_exitosa = True
            except Exception as e:
                print(f"      ⚠️ {metodo_nombre} falló: {str(e)[:80]}")
        
        if not copia_exitosa:
            print(f"   ❌ Todos los métodos de copia fallaron")
            return False, None
        
        # Verificar que se copió correctamente
        if os.path.exists(ruta_nueva):
            tamaño_original = os.path.getsize(archivo_descargado)
            tamaño_nuevo = os.path.getsize(ruta_nueva)
            
            if tamaño_nuevo > 0:
                print(f"   ✅ Archivo copiado exitosamente:")
                print(f"      • Tamaño original: {tamaño_original:,} bytes")
                print(f"      • Tamaño copia: {tamaño_nuevo:,} bytes")
                print(f"      • Ubicación: {ruta_nueva}")
                
                if tamaño_nuevo == tamaño_original:
                    print(f"      • Verificación: ✓ OK (tamaños coinciden)")
                else:
                    print(f"      • Verificación: ⚠️ ADVERTENCIA (tamaños diferentes)")
            else:
                print(f"   ⚠️ Archivo copiado pero está vacío (0 bytes)")
                return False, None
        else:
            print(f"   ❌ No se pudo crear el archivo en destino")
            return False, None
        
        # Intentar eliminar archivo original de descargas (no crítico)
        try:
            print(f"\n   🗑️  Intentando eliminar archivo original de descargas...")
            os.remove(archivo_descargado)
            print(f"   ✅ Archivo original eliminado")
        except Exception as e:
            print(f"   ⚠️ No se pudo eliminar el archivo original (no crítico): {e}")
        
        # Verificación final
        print(f"\n" + "="*60)
        print("📋 RESUMEN FINAL")
        print("="*60)
        print(f"   ✓ Archivo renombrado: {nombre_nuevo}")
        print(f"   ✓ Ubicación final: {ruta_destino}")
        print(f"   ✓ Ruta completa: {ruta_nueva}")
        print(f"   ✓ Tamaño final: {os.path.getsize(ruta_nueva):,} bytes")
        print(f"   ✓ Fecha del reporte: {fecha_ayer.strftime('%d/%m/%Y')}")
        
        # Listar archivos en la carpeta destino para verificación
        try:
            archivos_en_destino = os.listdir(ruta_destino)
            archivos_excel = [f for f in archivos_en_destino if f.endswith(('.xlsx', '.xls'))]
            print(f"   📁 Archivos Excel en destino: {len(archivos_excel)}")
            for archivo in archivos_excel[:5]:  # Mostrar primeros 5
                tamaño = os.path.getsize(os.path.join(ruta_destino, archivo))
                print(f"      • {archivo} ({tamaño:,} bytes)")
            if len(archivos_excel) > 5:
                print(f"      • ... y {len(archivos_excel) - 5} más")
        except Exception as e:
            print(f"   ⚠️ No se pudo listar archivos en destino: {e}")
        
        return True, ruta_nueva
        
    except Exception as e:
        print(f"   ❌ ERROR CRÍTICO al renombrar/mover archivo: {e}")
        import traceback
        traceback.print_exc()
        return False, None

