def marcar_todas_las_casillas(driver):
    """
    Hace scroll dentro del menú de columnas y marca TODAS las casillas
    que no estén marcadas (amarillo)
    """
    print("\n✅ MARCANDO TODAS LAS CASILLAS CON SCROLL...")
    time.sleep(2)
    
    # 1. ENCONTRAR EL CONTENEDOR PRINCIPAL CON SCROLL
    print("   🔍 Buscando contenedor del menú con scroll...")
    contenedor_scroll = None
    
    # Buscar diferentes tipos de contenedores con scroll
    selectores_contenedor = [
        "//div[contains(@class, 'k-list-container')]",
        "//div[contains(@class, 'k-popup')]",
        "//div[@role='listbox']",
        "//div[contains(@class, 'k-animation-container')]",
        "//div[contains(@class, 'k-columns-items')]",
        "//div[contains(@class, 'k-group')]"
    ]
    
    for selector in selectores_contenedor:
        try:
            contenedores = driver.find_elements(By.XPATH, selector)
            for contenedor in contenedores:
                if contenedor.is_displayed():
                    # Verificar si tiene scroll
                    try:
                        tiene_scroll = driver.execute_script("""
                            var elem = arguments[0];
                            return elem.scrollHeight > elem.clientHeight;
                        """, contenedor)
                        
                        if tiene_scroll:
                            contenedor_scroll = contenedor
                            print(f"   ✓ Contenedor con scroll encontrado: {selector}")
                            print(f"   📏 Tamaño: {contenedor.size}")
                            break
                    except:
                        # Si no se puede verificar scroll, asumir que es el contenedor
                        if contenedor.size['height'] > 200:
                            contenedor_scroll = contenedor
                            print(f"   ✓ Contenedor probable encontrado: {selector}")
                            break
            if contenedor_scroll:
                break
        except Exception as e:
            continue
    
    if not contenedor_scroll:
        print("   ⚠️ No se encontró contenedor específico, usando el diálogo completo")
        try:
            # Buscar el diálogo más cercano
            dialogo = driver.find_element(By.XPATH, "//div[contains(@class, 'k-window') or contains(@class, 'k-dialog')]")
            contenedor_scroll = dialogo
        except:
            contenedor_scroll = driver.find_element(By.TAG_NAME, "body")
    
    # 2. HACER SCROLL PARA CARGAR TODAS LAS CASILLAS
    print("   📜 Haciendo scroll para cargar todas las casillas...")
    
    altura_actual = 0
    intentos = 0
    max_intentos = 15  # Aumentado para asegurar scroll completo
    
    while intentos < max_intentos:
        try:
            # Obtener altura de scroll actual
            nueva_altura = driver.execute_script("""
                var cont = arguments[0];
                return cont.scrollTop || document.documentElement.scrollTop || document.body.scrollTop;
            """, contenedor_scroll)
            
            altura_maxima = driver.execute_script("""
                var cont = arguments[0];
                return cont.scrollHeight || document.documentElement.scrollHeight || document.body.scrollHeight;
            """, contenedor_scroll)
            
            print(f"      Scroll: {nueva_altura}/{altura_maxima} px")
            
            # Verificar si ya estamos al final
            if nueva_altura >= altura_maxima - 100 or nueva_altura == altura_actual:
                intentos += 1
                if intentos >= 3:  # Si no hay movimiento por 3 intentos, salir
                    print("      ✓ Llegó al final del scroll")
                    break
            else:
                intentos = 0  # Reiniciar contador si hubo movimiento
            
            # Hacer scroll hacia abajo
            driver.execute_script("""
                var cont = arguments[0];
                cont.scrollTop = cont.scrollTop + 300;
            """, contenedor_scroll)
            
            altura_actual = nueva_altura
            time.sleep(0.3)  # Esperar a que carguen nuevos elementos
            
        except Exception as e:
            print(f"      ⚠️ Error en scroll: {e}")
            break
    
    # 3. BUSCAR TODAS LAS CASILLAS DESPUÉS DEL SCROLL
    print("   🔍 Buscando TODAS las casillas después del scroll...")
    
    # Estrategia: buscar todos los elementos que podrían ser casillas
    todos_los_elementos_potenciales = []
    
    # Buscar por diferentes patrones
    patrones_busqueda = [
        "//*[contains(@class, 'k-checkbox')]",
        "//input[@type='checkbox']",
        "//span[contains(@class, 'k-checkbox')]",
        "//div[contains(@class, 'k-checkbox')]",
        "//label[contains(@class, 'k-checkbox')]",
        "//*[@role='checkbox']"
    ]
    
    for patron in patrones_busqueda:
        try:
            elementos = driver.find_elements(By.XPATH, patron)
            for elem in elementos:
                if elem.is_displayed() and elem not in todos_los_elementos_potenciales:
                    todos_los_elementos_potenciales.append(elem)
        except:
            continue
    
    print(f"   📊 Elementos potenciales encontrados: {len(todos_los_elementos_potenciales)}")
    
    # Filtrar elementos que realmente son casillas (visibles y con tamaño razonable)
    casillas_reales = []
    for elem in todos_los_elementos_potenciales:
        try:
            # Verificar que tenga tamaño razonable para ser una casilla
            tamaño = elem.size
            if tamaño['width'] > 10 and tamaño['height'] > 10:
                # Verificar que no sea un botón u otro elemento
                tag_name = elem.tag_name.lower()
                if tag_name != 'button' and tag_name != 'a':
                    casillas_reales.append(elem)
        except:
            continue
    
    print(f"   📊 Casillas reales filtradas: {len(casillas_reales)}")
    
    # Si no encontramos suficientes, buscar de otra manera
    if len(casillas_reales) < 5:
        print("   🔍 Buscando por estructura de Kendo UI...")
        # Buscar elementos dentro de items de lista
        try:
            items = driver.find_elements(By.XPATH, "//div[contains(@class, 'k-list-item')] | //li[contains(@class, 'k-item')]")
            for item in items:
                if item.is_displayed():
                    # Buscar checkboxes dentro del item
                    checkboxes = item.find_elements(By.XPATH, ".//*[contains(@class, 'k-checkbox')] | .//input[@type='checkbox']")
                    for cb in checkboxes:
                        if cb.is_displayed() and cb not in casillas_reales:
                            casillas_reales.append(cb)
        except:
            pass
    
    print(f"   📊 Total casillas a procesar: {len(casillas_reales)}")
    
    # 4. PROCESAR Y MARCAR TODAS LAS CASILLAS
    casillas_marcadas = 0
    casillas_ya_marcadas = 0
    
    print("   🎯 Procesando y marcando casillas...")
    
    for i, casilla in enumerate(casillas_reales, 1):
        try:
            # Asegurarse de que la casilla esté visible
            driver.execute_script("arguments[0].scrollIntoView({block: 'center', behavior: 'smooth'});", casilla)
            time.sleep(0.1)
            
            # Verificar estado actual
            esta_marcada = verificar_si_casilla_esta_marcada(casilla)
            
            if esta_marcada:
                casillas_ya_marcadas += 1
                print(f"      [{i:3d}] ✓ Ya marcada (amarillo)")
            else:
                print(f"      [{i:3d}] → Marcando (blanco a amarillo)...")
                
                # Intentar diferentes métodos para marcar
                marcada_exitosamente = False
                
                # Método 1: Clic con JavaScript
                try:
                    driver.execute_script("arguments[0].click();", casilla)
                    time.sleep(0.2)
                    
                    # Verificar si se marcó
                    if verificar_si_casilla_esta_marcada(casilla):
                        marcada_exitosamente = True
                except:
                    pass
                
                # Método 2: Clic directo
                if not marcada_exitosamente:
                    try:
                        casilla.click()
                        time.sleep(0.2)
                        if verificar_si_casilla_esta_marcada(casilla):
                            marcada_exitosamente = True
                    except:
                        pass
                
                # Método 3: Buscar input interno
                if not marcada_exitosamente:
                    try:
                        input_interno = casilla.find_element(By.XPATH, ".//input[@type='checkbox']")
                        driver.execute_script("arguments[0].click();", input_interno)
                        time.sleep(0.2)
                        if verificar_si_casilla_esta_marcada(casilla):
                            marcada_exitosamente = True
                    except:
                        pass
                
                # Método 4: Clic en área cercana (para Kendo UI)
                if not marcada_exitosamente:
                    try:
                        # Buscar elemento padre y hacer clic
                        padre = casilla.find_element(By.XPATH, "./parent::*")
                        driver.execute_script("arguments[0].click();", padre)
                        time.sleep(0.2)
                        if verificar_si_casilla_esta_marcada(casilla):
                            marcada_exitosamente = True
                    except:
