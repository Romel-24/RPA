def verificar_si_casilla_esta_marcada(elemento):
    """
    Verifica si una casilla de Kendo UI está marcada (amarillo)
    Retorna True si está marcada, False si no lo está
    """
    try:
        # Para Kendo UI, verificamos varias formas de determinar si está marcada
        
        # 1. Verificar clase 'k-checked' (común en Kendo UI)
        clases = elemento.get_attribute('class')
        if clases and ('k-checked' in clases or 'k-state-selected' in clases):
            return True
        
        # 2. Verificar atributo 'aria-checked'
        aria_checked = elemento.get_attribute('aria-checked')
        if aria_checked == 'true':
            return True
        
        # 3. Verificar input checkbox interno (si existe)
        try:
            input_checkbox = elemento.find_element(By.XPATH, ".//input[@type='checkbox']")
            if input_checkbox.is_selected():
                return True
        except:
            pass
        
        # 4. Verificar estilo visual - fondo amarillo
        try:
            color_fondo = elemento.value_of_css_property('background-color')
            # Buscar colores amarillos (rgb(255, 193, 7) o rgba(255, 193, 7, 1) o similares)
            if '255' in color_fondo and ('193' in color_fondo or '255, 255' in color_fondo):
                return True
        except:
            pass
        
        # 5. Verificar por el ícono de check (para Kendo UI)
        try:
            check_icon = elemento.find_element(By.XPATH, ".//span[contains(@class, 'k-checkbox-check')]")
            if check_icon.is_displayed():
                style = check_icon.get_attribute('style')
                if not style or 'none' not in style.lower():
                    return True
        except:
            pass
        
        return False
        
    except Exception as e:
        print(f"     ⚠️ Error verificando estado de casilla: {e}")
        return False

