        "//button[contains(text(), 'Exportar a excel') and not(@disabled)]",
        
        # Indicadores visuales de que los datos están cargados
        "//div[contains(@class, 'k-loading') and contains(@style, 'display: none')]",  # Spinner oculto
        "//div[contains(text(), 'filas') or contains(text(), 'registros') or contains(text(), 'resultados')]",
        
        # Elementos específicos de Kendo UI que indican carga completa
        "//div[contains(@class, 'k-pager-info')]",  # Información de paginación
        "//span[contains(@class, 'k-icon') and contains(@class, 'k-i-check')]",  # Íconos de check
    ]
    
    # Contador de verificación
    verificaciones_exitosas = 0
    verificaciones_necesarias = 3  # Necesitamos 3 verificaciones exitosas consecutivas
    
    while time.time() - tiempo_inicio < tiempo_maximo_espera:
        tiempo_transcurrido = int(time.time() - tiempo_inicio)
        print(f"   Verificando... ({tiempo_transcurrido}/{tiempo_maximo_espera} segundos)")
        
        # Verificar si hay spinners/loaders visibles
        try:
            spinners = driver.find_elements(By.XPATH, 
                "//div[contains(@class, 'k-loading') or contains(@class, 'loading') or contains(@class, 'spinner')]")
            spinners_visibles = [s for s in spinners if s.is_displayed()]
            
            if len(spinners_visibles) > 0:
                print(f"   ⏳ Spinner visible detectado, aún cargando...")
                verificaciones_exitosas = 0  # Reiniciar contador si hay spinner
                time.sleep(3)
                continue
        except:
            pass
        
        # Verificar indicadores de carga completa
        indicadores_encontrados = 0
        
        for indicador in indicadores_carga_completa:
            try:
                elementos = driver.find_elements(By.XPATH, indicador)
                for elemento in elementos:
                    if elemento.is_displayed():
                        # Para botones de exportación, verificar que estén habilitados
                        if 'button' in elemento.tag_name.lower() and 'exportar' in elemento.text.lower():
                            if elemento.is_enabled():
                                print(f"   ✓ Botón de exportación habilitado encontrado: '{elemento.text.strip()}'")
                                indicadores_encontrados += 1
                                break
                        else:
                            print(f"   ✓ Indicador de carga encontrado: {indicador[:50]}...")
                            indicadores_encontrados += 1
                            break
                if indicadores_encontrados > 0:
                    break
            except:
                continue
        
        # Si encontramos indicadores, incrementar contador
        if indicadores_encontrados > 0:
            verificaciones_exitosas += 1
            print(f"   ✅ Verificación {verificaciones_exitosas}/{verificaciones_necesarias} exitosa")
            
            if verificaciones_exitosas >= verificaciones_necesarias:
                print(f"\n   🎯 ¡VISTA PRELIMINAR COMPLETAMENTE CARGADA!")
                print(f"   Se encontraron {indicadores_encontrados} indicadores de carga completa")
                
                # Tomar captura final
                timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
                driver.save_screenshot(f"vista_previa_completa_{timestamp}.png")
                print(f"   📸 Captura guardada: vista_previa_completa_{timestamp}.png")
                
                # Hacer scroll para asegurar visibilidad
                driver.execute_script("window.scrollTo(0, document.body.scrollHeight);")
                time.sleep(2)
                
                return True
        else:
            verificaciones_exitosas = 0  # Reiniciar contador si no hay indicadores
            print(f"   ⏳ Esperando más tiempo para que cargue...")
        
        # Verificar errores
        try:
            errores = driver.find_elements(By.XPATH, 
                "//*[contains(text(), 'error') or contains(text(), 'Error') or contains(text(), 'ERROR')]")
            for error in errores:
                if error.is_displayed():
                    error_text = error.text[:100] if error.text else "Error sin texto"
                    print(f"   ⚠️ Se detectó un mensaje de error: {error_text}")
                    return False
        except:
            pass
        
        # Esperar antes de la próxima verificación
        time.sleep(5)
    
    print(f"\n⚠️  Tiempo de espera excedido ({tiempo_maximo_espera} segundos)")
    print("   Intentando continuar de todos modos...")
    
    # Tomar captura final de estado
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    driver.save_screenshot(f"tiempo_espera_excedido_{timestamp}.png")
    
    # Intentar buscar el botón de exportación una última vez
    try:
        boton_exacto = driver.find_elements(By.XPATH, "//button[text()='Exportar a excel']")
        for boton in boton_exacto:
            if boton.is_displayed() and boton.is_enabled():
                print(f"   ✅ Botón encontrado después del tiempo de espera!")
                return True
    except:
        pass
    
    return True  # Intentar continuar de todos modos

def hacer_clic_boton_exportacion(elemento, driver, metodo_deteccion):
    """
    Función auxiliar para hacer clic en el botón de exportación
    con múltiples métodos de clic.
    """
    print(f"\n   🎯 CLIC EN BOTÓN DETECTADO POR: {metodo_deteccion}")
    
    texto = elemento.text.strip() if elemento.text else "Sin texto"
    tag_name = elemento.tag_name
    
    print(f"   📝 Información del botón:")
    print(f"      • Tag: <{tag_name}>")
    print(f"      • Texto: '{texto}'")
    print(f"      • Método: {metodo_deteccion}")
    
    # Intentar múltiples métodos de clic
    metodos_exitosos = []
    
    # Método 1: JavaScript (más confiable)
    try:
        print(f"      Método 1: JavaScript click...")
        driver.execute_script("arguments[0].click();", elemento)
        print(f"      ✅ ¡CLIC CON JAVASCRIPT EXITOSO!")
        metodos_exitosos.append("JavaScript")
    except Exception as e1:
        print(f"      ⚠️ Error JavaScript: {str(e1)[:50]}")
    
    # Método 2: ActionChains (más preciso)
    try:
        print(f"      Método 2: ActionChains click...")
        from selenium.webdriver.common.action_chains import ActionChains
        actions = ActionChains(driver)
        actions.move_to_element(elemento).pause(0.5).click().pause(0.5).perform()
        print(f"      ✅ ¡CLIC CON ACTIONCHAINS EXITOSO!")
        metodos_exitosos.append("ActionChains")
    except Exception as e2:
        print(f"      ⚠️ Error ActionChains: {str(e2)[:50]}")
    
    # Método 3: Clic normal
    try:
        print(f"      Método 3: Clic normal...")
        elemento.click()
        print(f"      ✅ ¡CLIC NORMAL EXITOSO!")
        metodos_exitosos.append("Normal")
    except Exception as e3:
        print(f"      ⚠️ Error clic normal: {str(e3)[:50]}")
    
    if metodos_exitosos:
        print(f"\n      ✅ ¡CLIC REALIZADO EXITOSAMENTE!")
        print(f"      Métodos exitosos: {', '.join(metodos_exitosos)}")
        
        # Esperar tiempo suficiente para la descarga
        print(f"      ⏱️  Esperando 15 segundos para la descarga...")
        time.sleep(15)
        
        # Tomar captura después del clic
        timestamp_despues = datetime.now().strftime("%Y%m%d_%H%M%S")
        driver.save_screenshot(f"despues_exportar_{timestamp_despues}.png")
        print(f"      📸 Captura posterior guardada")
        
        return True
    else:
        print(f"\n      ❌ NINGÚN MÉTODO DE CLIC FUNCIONÓ")
        return False

