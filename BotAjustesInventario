def ingresar_fecha_sin_barras(driver, elemento, fecha_texto_sin_barras):
    """
    Método optimizado para ingresar fechas sin barras.
    fecha_texto_sin_barras debe estar en formato: DDMMYYYY (ej: 01122025)
    """
    try:
        fecha_visual = f"{fecha_texto_sin_barras[:2]}/{fecha_texto_sin_barras[2:4]}/{fecha_texto_sin_barras[4:]}"
        
        print(f"   Intentando ingresar: {fecha_visual}")
        
        elemento.click()
        time.sleep(0.3)
        
        elemento.send_keys(Keys.CONTROL + "a")
        elemento.send_keys(Keys.BACKSPACE)
        time.sleep(0.2)
        
        elemento.send_keys(fecha_texto_sin_barras)
        time.sleep(0.3)
        
        driver.execute_script("""
            arguments[0].dispatchEvent(new Event('input', { bubbles: true }));
            arguments[0].dispatchEvent(new Event('change', { bubbles: true }));
            arguments[0].dispatchEvent(new Event('blur', { bubbles: true }));
        """, elemento)
        
        elemento.send_keys(Keys.TAB)
        time.sleep(0.2)
        
        print(f"   ✓ Fecha ingresada sin barras: {fecha_texto_sin_barras}")
        return True
        
    except Exception as e:
        print(f"   ✗ Error al ingresar fecha: {e}")
        return False

def buscar_panel_resultados(driver):
    """
    Busca el panel 'Resultados' en la parte inferior de la página
    """
    print("\n🔍 Buscando panel 'Resultados'...")
    
    xpaths_panel_resultados = [
        "//*[contains(text(), 'Resultados')]",
        "//div[contains(text(), 'Resultados')]",
        "//h2[contains(text(), 'Resultados')]",
        "//h3[contains(text(), 'Resultados')]",
        "//*[contains(@id, 'result')]",
        "//div[contains(@class, 'result')]",
    ]
    
    for xpath in xpaths_panel_resultados:
        try:
            elementos = driver.find_elements(By.XPATH, xpath)
            for elemento in elementos:
                if elemento.is_displayed():
                    print(f"   ✓ Panel 'Resultados' encontrado con XPath: {xpath}")
                    return elemento
        except:
            continue
    
    return None

def hacer_clic_en_boton_tres_puntos_sucursal(driver):
