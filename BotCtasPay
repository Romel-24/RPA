def esperar(driver, xpath: str, timeout: int = TIMEOUT_CORTO) -> WebElement:
    return WebDriverWait(driver, timeout).until(EC.presence_of_element_located((By.XPATH, xpath)))

def esperar_clickable(driver, xpath: str, timeout: int = TIMEOUT_CORTO) -> WebElement:
    return WebDriverWait(driver, timeout).until(EC.element_to_be_clickable((By.XPATH, xpath)))

def click_seguro(driver, xpath: str, timeout: int = TIMEOUT_CORTO) -> None:
    fin = time.time() + timeout
    while time.time() < fin:
        if not verificar_driver(driver):
            raise WebDriverException("Driver no responde")
        try:
            el = WebDriverWait(driver, 5).until(EC.element_to_be_clickable((By.XPATH, xpath)))
            driver.execute_script("arguments[0].scrollIntoView({block:'center'});", el)
            time.sleep(0.3)
            try:
                el.click()
            except:
                ActionChains(driver).move_to_element(el).click().perform()
            return
        except Exception:
            try:
                el = driver.find_element(By.XPATH, xpath)
                driver.execute_script("arguments[0].click();", el)
                return
            except:
                pass
        time.sleep(0.5)
    raise TimeoutException(f"No se pudo hacer click en {xpath}")

def manejar_confirmacion_exportacion(driver):
    """Verifica si aparece la ventana de confirmación de exportación y hace clic en 'Sí'."""
    try:
        # Esperar un momento corto a que aparezca el diálogo
        boton_si = WebDriverWait(driver, 5).until(
            EC.element_to_be_clickable((By.XPATH, XP_BOTON_SI))
        )
        print("[!] Ventana de confirmación de exportación detectada. Haciendo clic en 'Sí'...")
        boton_si.click()
        time.sleep(1)
        return True
    except TimeoutException:
        # No apareció el diálogo, seguir normalmente
        return False

