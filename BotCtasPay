def login(driver) -> None:
    print("[*] Cargando página de login...")
    navegar_con_reintentos(driver, URL_LOGIN)
    driver.maximize_window()
    usuario = esperar(driver, XP_LOGIN_USER, TIMEOUT_MEDIO)
    usuario.send_keys(USUARIO)
    password = esperar(driver, XP_LOGIN_PASS, TIMEOUT_MEDIO)
    password.send_keys(CONTRASENA)
    password.send_keys(Keys.ENTER)
    print("[*] Login enviado, esperando sesión...")
    WebDriverWait(driver, TIMEOUT_MEDIO).until(EC.invisibility_of_element_located((By.XPATH, XP_LOGIN_USER)))
    WebDriverWait(driver, TIMEOUT_MEDIO).until(EC.presence_of_element_located((By.TAG_NAME, "app-layout")))
    time.sleep(2)
    print("[*] Sesión establecida correctamente.")
    sys.stdout.flush()

def ir_al_modulo(driver) -> None:
    print(f"[*] Navegando al módulo: {URL_MODULO}")
    navegar_con_reintentos(driver, URL_MODULO)
    esperar(driver, XP_ESTATUS, TIMEOUT_MEDIO)
    print("[*] Módulo cargado correctamente.")
    sys.stdout.flush()

def aplicar_filtros_fijos(driver) -> None:
