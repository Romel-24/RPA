def construir_driver() -> webdriver.Chrome:
    opts = Options()
    opts.add_argument("--start-maximized")
    opts.add_argument("--disable-notifications")
    opts.add_argument("--disable-gpu")
    opts.add_argument("--no-sandbox")
    opts.add_argument("--disable-dev-shm-usage")
    opts.add_argument("--disable-blink-features=AutomationControlled")
    opts.add_argument("--disable-infobars")
    opts.add_argument("--disable-backgrounding-occluded-windows")
    opts.add_experimental_option("excludeSwitches", ["enable-automation"])
    opts.add_experimental_option("useAutomationExtension", False)
    opts.add_experimental_option("prefs", {
        "download.default_directory": CARPETA_DESCARGA,
        "download.prompt_for_download": False,
        "download.directory_upgrade": True,
        "safebrowsing.enabled": True,
    })
    if _USE_WDM:
        service = Service(ChromeDriverManager().install())
        driver = webdriver.Chrome(service=service, options=opts)
    else:
        driver = webdriver.Chrome(options=opts)
    
    # Script para ocultar la automatización
    script = """
    Object.defineProperty(navigator, 'webdriver', {
        get: () => undefined
    });
    delete window.cdc_adoQpoasnfa76pfcZLmcfl_Array;
    delete window.cdc_adoQpoasnfa76pfcZLmcfl_Promise;
    delete window.cdc_adoQpoasnfa76pfcZLmcfl_Symbol;
    """
    driver.execute_cdp_cmd("Page.addScriptToEvaluateOnNewDocument", {"source": script})
    
    driver.set_page_load_timeout(TIMEOUT_LARGO)
    driver.set_script_timeout(TIMEOUT_LARGO)
    try:
        driver.command_executor._client.timeout = 600
    except:
        pass
    return driver

def verificar_driver(driver):
    try:
        driver.current_url
        return True
    except WebDriverException:
        return False

def reiniciar_driver(driver_actual, destino_dir, carpeta_descarga) -> webdriver.Chrome:
    print("[*] Reiniciando el driver completamente...")
    try:
        driver_actual.quit()
    except:
        pass
    time.sleep(5)
    nuevo_driver = construir_driver()
    login(nuevo_driver)
    ir_al_modulo(nuevo_driver)
    aplicar_filtros_fijos(nuevo_driver)
    return nuevo_driver

def navegar_con_reintentos(driver, url, max_reintentos=3):
    """
    Navega a una URL con reintentos y, en caso de error de conexión,
    reinicia el driver y vuelve a loguearse.
    """
    for intento in range(1, max_reintentos + 1):
        try:
            driver.get(url)
            return True
        except (TimeoutException, WebDriverException, ConnectionError) as e:
            print(f"[!] Error al navegar a {url} (intento {intento}/{max_reintentos}): {type(e).__name__}")
            if intento == max_reintentos:
                raise
            print("[*] Reintentando navegación después de 10 segundos...")
            time.sleep(10)
            # Si el error es de conexión (driver muerto), lo reiniciamos
            if isinstance(e, ConnectionError) or "WinError 10061" in str(e) or "MaxRetryError" in str(e):
                print("[!] Conexión perdida, reiniciando el driver...")
                try:
                    driver.quit()
                except:
                    pass
                driver = construir_driver()
                login(driver)
                ir_al_modulo(driver)
                aplicar_filtros_fijos(driver)
    return False

# =============================================================================
# ESPERA INTELIGENTE (con límite de tiempo para la carga posterior a Buscar)
# =============================================================================

def esperar_fin_carga(driver, mensaje_extra: str = "", timeout_total: int = TIMEOUT_CARGA_VISTA_PREVIA) -> None:
    """
    Espera a que desaparezcan spinner y texto 'Por favor espere', con un tiempo máximo global.
    Luego espera a que el botón Exportar sea clickeable.
    Finalmente, espera a que aparezca un indicador de que la tabla está lista
    (texto 'Mostrando' o presencia de filas), o fuerza una pausa adicional de 8 segundos.
    
    Si se supera el timeout_total, lanza TimeoutException.
    """
    print(f"[*] Esperando a que termine la carga (spinner, texto y botón Exportar)... {mensaje_extra}")
    inicio = time.time()
    
    # 1. Esperar indefinidamente o hasta timeout a que desaparezca el spinner
    while True:
        if time.time() - inicio > timeout_total:
            raise TimeoutException(f"Timeout esperando desaparición del spinner después de {timeout_total} segundos.")
        if not verificar_driver(driver):
            raise WebDriverException("El driver ha perdido comunicación con el navegador.")
        try:
            spinner = driver.find_element(By.XPATH, XP_SPINNER)
            if not spinner.is_displayed():
                break
        except:
            break
        time.sleep(1)
    
    # 2. Esperar indefinidamente o hasta timeout a que desaparezca el texto "Por favor espere"
    while True:
        if time.time() - inicio > timeout_total:
            raise TimeoutException(f"Timeout esperando desaparición del texto de carga después de {timeout_total} segundos.")
        if not verificar_driver(driver):
            raise WebDriverException("El driver ha perdido comunicación con el navegador.")
        try:
            texto = driver.find_element(By.XPATH, XP_TEXTO_CARGA)
            if not texto.is_displayed():
                break
        except:
            break
        time.sleep(1)
    
    # 3. Esperar a que el botón Exportar sea clickeable (con timeout muy alto)
    try:
        WebDriverWait(driver, TIMEOUT_LARGO).until(
            EC.element_to_be_clickable((By.XPATH, XP_EXPORTAR))
        )
    except TimeoutException as e:
        raise TimeoutException(f"El botón Exportar no se volvió clickeable después de {TIMEOUT_LARGO} segundos.") from e
    
    # 4. Esperar a que aparezca algún indicador de que la tabla está cargada
    try:
        WebDriverWait(driver, 30).until(
            EC.presence_of_element_located((By.XPATH, XP_TABLA_LISTA))
        )
        print("[*] Tabla o indicador de carga detectado.")
    except TimeoutException:
        print("[!] No se encontró indicador de tabla lista; se aplicará una pausa adicional de 8 segundos.")
        time.sleep(8)
    
    print("[*] Carga completada. Pausa de 2 segundos para estabilizar pantalla...")
    time.sleep(2)
    sys.stdout.flush()

