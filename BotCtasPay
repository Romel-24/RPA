    click_seguro(driver, XP_ESTATUS)
    for xp in XP_ESTATUS_OPCIONES:
        click_seguro(driver, xp)
    click_seguro(driver, XP_ESTATUS)

    print("[*] Aplicando filtro: Tipo documento operación (todas)")
    click_seguro(driver, XP_TIPO_DOC)
    click_seguro(driver, XP_TIPO_DOC_TODOS)
    click_seguro(driver, XP_TIPO_DOC)

    print("[*] Aplicando filtro: Clasificación del proveedor")
    click_seguro(driver, XP_CLAS_PROV)
    for xp in XP_CLAS_PROV_OPCIONES:
        click_seguro(driver, xp)
    click_seguro(driver, XP_CLAS_PROV)

    # El filtro "Tipo de rango -> Diferente de <>" ha sido eliminado.
    
    print("[*] Aplicando filtro: Fecha a filtrar -> Fecha de contabilización")
    click_seguro(driver, XP_FECHA_FILTRAR)
    click_seguro(driver, XP_FECHA_FILTRAR_CONTABILIZACION)
    sys.stdout.flush()

def seleccionar_fecha(driver, xp_campo, xp_btn_anio, lista_meses, fecha):
    fecha_str = fecha.strftime("%d/%m/%Y")
    print(f"    -> Seleccionando fecha {fecha_str}")
    sys.stdout.flush()

    click_seguro(driver, xp_campo)
    time.sleep(0.5)

    click_seguro(driver, xp_btn_anio)
    time.sleep(0.5)

    if lista_meses is MESES_INICIO:
        contenedor = XP_FECHA_INICIO_CONTENEDOR
    else:
        contenedor = XP_FECHA_FIN_CONTENEDOR

    indice_anio = fecha.year - 2019
    xpath_anio = f"{contenedor}/div[2]/span[{indice_anio}]"
    click_seguro(driver, xpath_anio)
    time.sleep(0.5)
    print(f"    -> Año {fecha.year} seleccionado")

    indice_mes = fecha.month - 1
    xp_mes = lista_meses[indice_mes]
    click_seguro(driver, xp_mes)
    time.sleep(0.5)
    print(f"    -> Mes {fecha.strftime('%B')} seleccionado")

    xpath_dia = f"{contenedor}//td[not(contains(@class, 'p-datepicker-other-month'))]//span[text()='{fecha.day}']"
    click_seguro(driver, xpath_dia)
    time.sleep(0.5)
    print(f"    -> Día {fecha.day} seleccionado")

# =============================================================================
# DESCARGA Y RENOMBRADO (con manejo de confirmación y esperas mejoradas)
# =============================================================================

def esperar_descarga(timeout: int = ESPERA_DESCARGA) -> Path:
    fecha_hoy = datetime.now().date()
    print(f"[*] Monitoreando descargas en: {CARPETA_DESCARGA}")
    sys.stdout.flush()

    inicio = time.time()
    while time.time() - inicio < timeout:
        archivos = [f for f in os.listdir(CARPETA_DESCARGA) if f.lower().endswith(('.xlsx', '.xls')) and not f.endswith('.crdownload')]
        for archivo in archivos:
            ruta = Path(CARPETA_DESCARGA) / archivo
            try:
                mtime = datetime.fromtimestamp(os.path.getmtime(ruta)).date()
                if mtime == fecha_hoy and os.path.getsize(ruta) > 0:
                    time.sleep(2)
                    if os.path.getsize(ruta) > 0:
                        print(f"[*] Archivo detectado: {archivo}")
                        return ruta
            except Exception:
                continue
        time.sleep(1)
    raise TimeoutException("No se detectó ningún archivo Excel descargado hoy dentro del tiempo esperado.")

def mover_y_renombrar(origen: Path, destino_dir: str) -> Path:
    Path(destino_dir).mkdir(parents=True, exist_ok=True)
    fecha_actual = datetime.now().strftime("%d%m%Y")
    nombre_base = f"Cuentas_X_Pagar_{fecha_actual}.xlsx"
    destino = Path(destino_dir) / nombre_base
    if destino.exists():
        contador = 1
        while destino.exists():
            destino = Path(destino_dir) / f"Cuentas_X_Pagar_{fecha_actual}_{contador}.xlsx"
            contador += 1
    shutil.move(str(origen), str(destino))
    for _ in range(10):
        if destino.exists() and destino.stat().st_size > 0:
            break
        time.sleep(0.5)
    else:
        raise IOError(f"El archivo destino {destino} no se creó correctamente o está vacío.")
    return destino

def buscar_y_exportar(driver, destino_dir: str, es_ultimo_viaje: bool = False) -> Path:
    print("[*] Click en Buscar...")
    click_seguro(driver, XP_BUSCAR)
    sys.stdout.flush()

    esperar_fin_carga(driver, mensaje_extra="(después de Buscar)")

    if es_ultimo_viaje:
        print("[*] Último viaje detectado. Espera adicional de 5 segundos...")
        time.sleep(5)

    print("[*] Click en Exportar...")
    click_seguro(driver, XP_EXPORTAR)
    sys.stdout.flush()

    # Manejar la ventana de confirmación que puede aparecer inmediatamente después
    manejar_confirmacion_exportacion(driver)

    WebDriverWait(driver, TIMEOUT_MEDIO).until(
        EC.element_to_be_clickable((By.XPATH, XP_EXPORTAR_EXCEL))
    )
    print("[*] Click en opción Excel...")
    click_seguro(driver, XP_EXPORTAR_EXCEL)
    sys.stdout.flush()

    # Puede aparecer otra confirmación después de hacer clic en Excel
    manejar_confirmacion_exportacion(driver)

    # Esperar a que desaparezca cualquier spinner residual después del clic
    for _ in range(30):
        try:
            spinner = driver.find_element(By.XPATH, XP_SPINNER)
            if not spinner.is_displayed():
                break
        except:
            break
        time.sleep(1)
    time.sleep(2)

    archivo_descargado = esperar_descarga()
    print(f"[*] Archivo descargado: {archivo_descargado}")

    destino = mover_y_renombrar(archivo_descargado, destino_dir)
    print(f"[*] Archivo guardado como: {destino}")

    # Esperar a que no quede ningún indicador de carga
    print("[*] Verificando que no queden indicadores de carga residuales...")
    for _ in range(10):
        try:
            spinner = driver.find_element(By.XPATH, XP_SPINNER)
            if spinner.is_displayed():
                print("    Aún hay spinner, esperando...")
                time.sleep(1)
                continue
        except:
            pass
        try:
            texto = driver.find_element(By.XPATH, XP_TEXTO_CARGA)
            if texto.is_displayed():
                print("    Aún hay texto de carga, esperando...")
                time.sleep(1)
                continue
        except:
            pass
        break

    # Pausa final para estabilizar la página
    print("[*] Pausa de 15 segundos para que la página se estabilice completamente...")
    time.sleep(15)
    return destino

# =============================================================================
# FLUJO PRINCIPAL CON REINTENTOS, REFRESCO AUTOMÁTICO Y SINCRONIZACIÓN
# =============================================================================

def ejecutar_viaje(driver, viaje: Viaje, destino_dir: str, es_ultimo: bool = False) -> None:
    for intento in range(1, MAX_REINTENTOS + 1):
        print(f"\n{'='*70}\nVIAJE: {viaje.nombre} -> {viaje.fecha_inicio.strftime('%d/%m/%Y')} a {viaje.fecha_fin.strftime('%d/%m/%Y')} (Intento {intento}/{MAX_REINTENTOS})")
        print('='*70)
        sys.stdout.flush()

        try:
            if not verificar_driver(driver):
                print("[!] El driver parece muerto, reiniciando...")
                driver = reiniciar_driver(driver, destino_dir, CARPETA_DESCARGA)

            seleccionar_fecha(
                driver,
                XP_FECHA_INICIO_CAMPO,
                XP_FECHA_INICIO_BTN_ANIO,
                MESES_INICIO,
                viaje.fecha_inicio
            )

            seleccionar_fecha(
                driver,
                XP_FECHA_FIN_CAMPO,
                XP_FECHA_FIN_BTN_ANIO,
                MESES_FIN,
                viaje.fecha_fin
            )

            # Sub-bucle para manejar refrescos (F5) ante timeouts de carga posterior a Buscar
            max_refrescos = 3
            for refresh_intento in range(1, max_refrescos + 1):
                try:
                    buscar_y_exportar(driver, destino_dir, es_ultimo)
                    break  # Éxito, salir del sub-bucle
                except TimeoutException as e:
                    print(f"[!] Timeout en carga de vista previa (refresh intento {refresh_intento}/{max_refrescos}): {e}")
                    if refresh_intento == max_refrescos:
                        # Agotamos los refrescos, relanzamos para que el reintento global (reinicio de driver) actúe
                        raise
                    print("[*] Refrescando la página (F5) para restablecer la conexión...")
                    driver.refresh()
                    time.sleep(5)
                    # Esperar a que la página recargue y el módulo esté presente
                    WebDriverWait(driver, TIMEOUT_MEDIO).until(
                        EC.presence_of_element_located((By.XPATH, XP_ESTATUS))
                    )
                    # Re-aplicar filtros fijos y las fechas del viaje actual
                    aplicar_filtros_fijos(driver)
                    seleccionar_fecha(
                        driver,
                        XP_FECHA_INICIO_CAMPO,
                        XP_FECHA_INICIO_BTN_ANIO,
                        MESES_INICIO,
                        viaje.fecha_inicio
                    )
                    seleccionar_fecha(
                        driver,
                        XP_FECHA_FIN_CAMPO,
                        XP_FECHA_FIN_BTN_ANIO,
                        MESES_FIN,
                        viaje.fecha_fin
                    )
                    # Continúa con el siguiente intento de refresh

            print(f"[OK] Viaje {viaje.nombre} completado exitosamente en el intento {intento}.\n")
            sys.stdout.flush()
            # Pausa aumentada a 10 segundos antes del siguiente viaje
            print("[*] Esperando 10 segundos para resetear la interfaz antes del próximo viaje...")
            time.sleep(10)
            return

        except (TimeoutException, WebDriverException, ConnectionError, Exception) as e:
            error_tipo = type(e).__name__
            error_msg = str(e) if str(e) else "(mensaje vacío)"
            print(f"[ERROR] Falló el viaje {viaje.nombre} en intento {intento}/{MAX_REINTENTOS}: {error_tipo} - {error_msg}")

            if intento < MAX_REINTENTOS:
                print("[*] Reintentando con reinicio completo del driver...")
                try:
                    driver = reiniciar_driver(driver, destino_dir, CARPETA_DESCARGA)
                except Exception as reinicio_error:
                    print(f"[!] Error al reiniciar driver: {reinicio_error}")
                    time.sleep(30)
                    driver = construir_driver()
                    login(driver)
                    ir_al_modulo(driver)
                    aplicar_filtros_fijos(driver)
                time.sleep(15)
            else:
                print(f"[ERROR] Se agotaron los {MAX_REINTENTOS} intentos para el viaje {viaje.nombre}. Saltando al siguiente viaje.\n")
                raise

def main() -> None:
    Path(CARPETA_DESTINO).mkdir(parents=True, exist_ok=True)
    Path(CARPETA_DESCARGA).mkdir(parents=True, exist_ok=True)

    driver = construir_driver()
    try:
        login(driver)
        ir_al_modulo(driver)
        aplicar_filtros_fijos(driver)
        viajes = construir_viajes()
        for idx, viaje in enumerate(viajes):
            es_ultimo = (idx == len(viajes) - 1)
            try:
                ejecutar_viaje(driver, viaje, CARPETA_DESTINO, es_ultimo)
            except Exception as e:
                print(f"[ERROR] No se pudo completar el viaje {viaje.nombre} después de {MAX_REINTENTOS} intentos: {e}")
                try:
                    driver = reiniciar_driver(driver, CARPETA_DESTINO, CARPETA_DESCARGA)
                except:
                    driver = construir_driver()
                    login(driver)
                    ir_al_modulo(driver)
                    aplicar_filtros_fijos(driver)
                continue
        print("\n[OK] Proceso finalizado.")
    finally:
        driver.quit()

if __name__ == "__main__":
    main()
